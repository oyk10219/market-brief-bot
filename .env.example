NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# telegram, kakao, or telegram,kakao
SEND_CHANNELS=telegram

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Optional. Comma-separated chat IDs for sending to multiple private chats.
TELEGRAM_CHAT_IDS=
# Optional. Failure alerts are sent here first. If omitted, first TELEGRAM_CHAT_ID(S) recipient is used.
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# Optional KakaoTalk "send to me".
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_REDIRECT_URI=http://localhost:8765/kakao/callback
KAKAO_REFRESH_TOKEN=
KAKAO_CLIENT_SECRET=
KAKAO_LINK_URL=https://github.com/oyk10219/market-brief-bot
KAKAO_MAX_TEXT_LENGTH=200

# Optional. If omitted, the DART step is skipped.
DART_API_KEY=your_dart_api_key

# Optional.
REQUEST_TIMEOUT=15
DART_LOOKBACK_DAYS=7
DART_TARGET_COMPANIES=싸이토젠,경인양행

# Optional local-only summary. Use this from Windows Scheduler, not GitHub Actions.
SUMMARY_PROVIDER=
CODEX_MODEL=gpt-5.2
CODEX_TIMEOUT_SECONDS=300

# Optional article body extraction for better summaries.
ARTICLE_FETCH_ENABLED=true
ARTICLE_FETCH_PER_SECTION=3
ARTICLE_FETCH_MAX_CHARS=2500
ARTICLE_FETCH_TIMEOUT=10

# Optional news quality filter.
NEWS_FILTER_ENABLED=true

# Telegram output mode.
TELEGRAM_DETAIL_MODE=compact
TELEGRAM_LINKS_PER_SECTION=1
